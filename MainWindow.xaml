                                    BorderBrush="{StaticResource YellowBrush}"
                                    BorderThickness="2" CornerRadius="4" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="PORT 2 — LATEST FRAME" FontSize="12"
                                               FontWeight="Bold" Foreground="{StaticResource YellowBrush}"
                                               Margin="0,0,0,10"/>
                                    <TextBlock Text="[Live data will appear here when connected]"
                                               FontSize="11" FontFamily="Consolas"
                                               Foreground="{StaticResource SubTextBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════
     TAB 4: RX LIVE STATS
     Displays GenerateDetailedDisplay() output — latest frame only
     No accumulation — no tab switch hang
════════════════════════════════════════════════════════════ -->
            <TabItem Header="RX LIVE STATS" Style="{StaticResource DarkTabItem}">
                <Grid Background="{StaticResource MidBgBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ══════════════════════════════════════════
             PORT 1 — RX LIVE STATS
        ═══════════════════════════════════════════════ -->
                    <Border Grid.Column="0"
                Background="{StaticResource MidBgBrush}"
                BorderBrush="{StaticResource GreenBrush}"
                BorderThickness="2"
                CornerRadius="4"
                Margin="4,6,2,6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36"/>
                                <!-- Header      -->
                                <RowDefinition Height="28"/>
                                <!-- Stats strip -->
                                <RowDefinition Height="*"/>
                                <!-- Detail text -->
                                <RowDefinition Height="36"/>
                                <!-- File path   -->
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Border Grid.Row="0"
                        Background="{StaticResource PanelBgBrush}"
                        CornerRadius="2,2,0,0">
                                <Grid Margin="10,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Ellipse Grid.Column="0"
                                 Width="12" Height="12"
                                 Margin="0,0,8,0">
