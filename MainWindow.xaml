                                            <SolidColorBrush Color="{Binding Port1.PortStatusColor}"/>
                                        </Ellipse.Fill>
                                    </Ellipse>

                                    <TextBlock Grid.Column="1"
                                   Text="PORT 1  —  RX LIVE HEALTH STATUS"
