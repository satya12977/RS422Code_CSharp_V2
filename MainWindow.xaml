                                   FontWeight="Bold"
                                   Foreground="{StaticResource GreenBrush}"
                                   VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="2"
                                   Text="[" FontSize="12"
                                   Foreground="{StaticResource SubTextBrush}"
                                   VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3"
                                   Text="{Binding Port1.SelectedPort}"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource YellowBrush}"
                                   VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4"
                                   Text="]"
                                   FontSize="12"
                                   Foreground="{StaticResource SubTextBrush}"
                                   VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Stats strip -->
                            <Border Grid.Row="1"
                        Background="#FF070C18"
                        BorderBrush="{StaticResource PanelBgBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="10,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="STATUS: "
                                   FontSize="10"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port1.ConnectionLabel}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{Binding Port1.IsConnected,
                                               Converter={StaticResource ConnBrushConv}}"
                                   Margin="0,0,20,0"/>

                                    <TextBlock Text="TOTAL: "
                                   FontSize="10"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port1.TotalFrames}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,20,0"/>

                                    <TextBlock Text="VALID: "
                                   FontSize="10"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port1.ValidFrames}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource GreenBrush}"
                                   Margin="0,0,20,0"/>

                                    <TextBlock Text="INVALID: "
                                   FontSize="10"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port1.InvalidFrames}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource AccentBrush}"
                                   Margin="0,0,20,0"/>

                                    <TextBlock Text="SHOWING: "
                                   FontSize="10"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="LATEST FRAME ONLY"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource YellowBrush}"/>
                                </StackPanel>
                            </Border>

                            <!-- Detailed display TextBox
                     RxLiveLog = single latest GenerateDetailedDisplay() entry
                     No large string join = no tab switch hang -->
                            <TextBox Grid.Row="2"
                         Name="TbPort1RxLive"
                         Background="#FF080D18"
                         Foreground="{StaticResource GreenBrush}"
                         FontFamily="Consolas"
                         FontSize="11"
                         BorderThickness="0"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"
                         AcceptsReturn="True"
                         Text="{Binding Port1.RxLiveLog, Mode=OneWay}"
                         TextChanged="TbPort1RxLive_TextChanged"
                         Margin="4"
                         Padding="8,6"/>

                            <!-- File path row -->
                            <Border Grid.Row="3"
                        Background="#FF070C18"
                        BorderBrush="{StaticResource PanelBgBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="8,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="LOG: "
                                   FontSize="9"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port1.RxLiveLogFilePath,
                                         Mode=OneWay}"
                                   FontSize="9"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource GreenBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1"
                      Width="6"
                      Background="{StaticResource DarkBgBrush}"
                      HorizontalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext"/>

                    <!-- ══════════════════════════════════════════
             PORT 2 — RX LIVE STATS
        ═══════════════════════════════════════════════ -->
                    <Border Grid.Column="2"
                Background="{StaticResource MidBgBrush}"
                BorderBrush="{StaticResource YellowBrush}"
                BorderThickness="2"
                CornerRadius="4"
                Margin="2,6,4,6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="36"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Border Grid.Row="0"
                        Background="{StaticResource PanelBgBrush}"
                        CornerRadius="2,2,0,0">
                                <Grid Margin="10,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Ellipse Grid.Column="0"
                                 Width="12" Height="12"
                                 Margin="0,0,8,0">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{Binding Port2.PortStatusColor}"/>
                                        </Ellipse.Fill>
                                    </Ellipse>

                                    <TextBlock Grid.Column="1"
                                   Text="PORT 2  —  RX LIVE HEALTH STATUS"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource YellowBrush}"
                                   VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="2"
                                   Text="["
                                   FontSize="12"
                                   Foreground="{StaticResource SubTextBrush}"
                                   VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3"
                                   Text="{Binding Port2.SelectedPort}"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource GreenBrush}"
                                   VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4"
                                   Text="]"
                                   FontSize="12"
                                   Foreground="{StaticResource SubTextBrush}"
                                   VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Stats strip -->
                            <Border Grid.Row="1"
                        Background="#FF070C18"
                        BorderBrush="{StaticResource PanelBgBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="10,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="STATUS: "
                                   FontSize="10"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port2.ConnectionLabel}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{Binding Port2.IsConnected,
                                               Converter={StaticResource ConnBrushConv}}"
                                   Margin="0,0,20,0"/>

                                    <TextBlock Text="TOTAL: "
                                   FontSize="10"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port2.TotalFrames}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,20,0"/>

                                    <TextBlock Text="VALID: "
                                   FontSize="10"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port2.ValidFrames}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource GreenBrush}"
                                   Margin="0,0,20,0"/>

                                    <TextBlock Text="INVALID: "
                                   FontSize="10"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port2.InvalidFrames}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource AccentBrush}"
                                   Margin="0,0,20,0"/>

                                    <TextBlock Text="SHOWING: "
                                   FontSize="10"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="LATEST FRAME ONLY"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource YellowBrush}"/>
                                </StackPanel>
                            </Border>

                            <!-- Detailed display TextBox -->
                            <TextBox Grid.Row="2"
                         Name="TbPort2RxLive"
                         Background="#FF080D18"
                         Foreground="{StaticResource YellowBrush}"
                         FontFamily="Consolas"
                         FontSize="11"
                         BorderThickness="0"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"
                         AcceptsReturn="True"
                         Text="{Binding Port2.RxLiveLog, Mode=OneWay}"
                         TextChanged="TbPort2RxLive_TextChanged"
                         Margin="4"
                         Padding="8,6"/>

                            <!-- File path row -->
                            <Border Grid.Row="3"
                        Background="#FF070C18"
                        BorderBrush="{StaticResource PanelBgBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="8,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="LOG: "
                                   FontSize="9"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="{Binding Port2.RxLiveLogFilePath,
                                         Mode=OneWay}"
                                   FontSize="9"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource YellowBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════
     TAB 5: OFFLINE COMPARE (FIXED WITH SCROLLVIEWER & PROGRESS)
════════════════════════════════════════════════════════════ -->
            <TabItem Header="📁 OFFLINE COMPARE" Style="{StaticResource DarkTabItem}">
                <Border Background="{StaticResource MidBgBrush}"
            BorderBrush="{StaticResource PanelBgBrush}"
            BorderThickness="1" CornerRadius="4" Margin="4">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
                        <Grid Margin="0,0,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- Header -->
                                <RowDefinition Height="Auto"/>
                                <!-- Mode selection -->
                                <RowDefinition Height="Auto"/>
                                <!-- File selection -->
                                <RowDefinition Height="Auto"/>
                                <!-- Control buttons -->
                                <RowDefinition Height="Auto"/>
                                <!-- Progress bar -->
                                <RowDefinition Height="400"/>
                                <!-- Results (fixed height) -->
                                <RowDefinition Height="Auto"/>
                                <!-- Status bar -->
                            </Grid.RowDefinitions>

                            <!-- ══════════════════════════════════════════════════════════════
                     HEADER
                ═══════════════════════════════════════════════════════════════ -->
                            <Border Grid.Row="0" Background="{StaticResource PanelBgBrush}"
                        CornerRadius="4,4,0,0" Padding="12,10">
                                <StackPanel>
                                    <TextBlock Text="OFFLINE LOG FILE COMPARISON" FontSize="14"
                                   FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                                    <TextBlock Text="Compare expected 8-byte commands with actual log files • Loop detection • Multi-file fallback"
                                   FontSize="11" Foreground="{StaticResource SubTextBrush}"/>
                                </StackPanel>
                            </Border>

                            <!-- ══════════════════════════════════════════════════════════════
                     MODE SELECTION
                ═══════════════════════════════════════════════════════════════ -->
                            <Border Grid.Row="1" Background="#FF0D1526" Margin="10,10,10,0"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="12,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="COMPARISON MODE:" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center" Margin="0,0,15,0"/>

                                    <RadioButton Content="Single File (Loop Detection: 320 commands/loop)"
                                     IsChecked="{Binding OfflineCompare.UseSingleFileMode}"
                                     Foreground="{StaticResource TextBrush}"
                                     FontSize="11" Margin="0,0,20,0"
                                     VerticalAlignment="Center"/>

                                    <RadioButton Content="Multi-File (Fallback to 2nd/3rd files)"
                                     IsChecked="{Binding OfflineCompare.UseMultiFileMode}"
                                     Foreground="{StaticResource TextBrush}"
                                     FontSize="11"
                                     VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- ══════════════════════════════════════════════════════════════
                     FILE SELECTION
                ═══════════════════════════════════════════════════════════════ -->
                            <Grid Grid.Row="2" Margin="10,10,10,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Expected file -->
                                <Border Grid.Row="0" Background="#FF0D1526"
                            BorderBrush="{StaticResource YellowBrush}"
                            BorderThickness="2" CornerRadius="4" Padding="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="EXPECTED COMMANDS:"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource YellowBrush}"
                                       VerticalAlignment="Center"/>

                                        <TextBox Grid.Column="1"
                                     Text="{Binding OfflineCompare.ExpectedFilePath}"
                                     Style="{StaticResource LogTextBox}"
                                     IsReadOnly="True" Height="28"
                                     VerticalContentAlignment="Center"
                                     Margin="5,0"/>

                                        <Button Grid.Column="2" Content="📂  BROWSE"
                                    Style="{StaticResource ProfessionalButton}"
                                    Height="28"
                                    Click="BtnBrowseExpected_Click"/>
                                    </Grid>
                                </Border>

                                <!-- Actual files -->
                                <Border Grid.Row="2" Background="#FF0D1526"
                            BorderBrush="{StaticResource GreenBrush}"
                            BorderThickness="2" CornerRadius="4" Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="ACTUAL LOG FILE(S):" FontSize="11"
                                       FontWeight="Bold" Foreground="{StaticResource GreenBrush}"
                                       Margin="0,0,0,8"/>

                                        <!-- File 1 -->
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="FILE 1:"
                                           FontSize="10" Foreground="{StaticResource SubTextBrush}"
                                           VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1"
                                         Text="{Binding OfflineCompare.ActualFile1Path}"
                                         Style="{StaticResource LogTextBox}"
                                         IsReadOnly="True" Height="26"
                                         VerticalContentAlignment="Center"
                                         Margin="0,0,5,0"/>
                                            <Button Grid.Column="2" Content="BROWSE"
                                        Style="{StaticResource ProfessionalButton}"
                                        Height="26"
                                        Click="BtnBrowseActual1_Click"/>
                                        </Grid>

                                        <!-- File 2 (multi-file mode) -->
                                        <Grid Margin="0,0,0,6"
                                  IsEnabled="{Binding OfflineCompare.UseMultiFileMode}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="FILE 2:"
                                           FontSize="10" Foreground="{StaticResource SubTextBrush}"
                                           VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1"
                                         Text="{Binding OfflineCompare.ActualFile2Path}"
                                         Style="{StaticResource LogTextBox}"
                                         IsReadOnly="True" Height="26"
                                         VerticalContentAlignment="Center"
                                         Margin="0,0,5,0"/>
                                            <Button Grid.Column="2" Content="BROWSE"
                                        Style="{StaticResource ProfessionalButton}"
                                        Height="26"
                                        Click="BtnBrowseActual2_Click"/>
                                        </Grid>

                                        <!-- File 3 (multi-file mode) -->
                                        <Grid IsEnabled="{Binding OfflineCompare.UseMultiFileMode}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="FILE 3:"
                                           FontSize="10" Foreground="{StaticResource SubTextBrush}"
                                           VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1"
                                         Text="{Binding OfflineCompare.ActualFile3Path}"
                                         Style="{StaticResource LogTextBox}"
                                         IsReadOnly="True" Height="26"
                                         VerticalContentAlignment="Center"
                                         Margin="0,0,5,0"/>
                                            <Button Grid.Column="2" Content="BROWSE"
                                        Style="{StaticResource ProfessionalButton}"
                                        Height="26"
                                        Click="BtnBrowseActual3_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- ══════════════════════════════════════════════════════════════
                     CONTROL BUTTONS
                ═══════════════════════════════════════════════════════════════ -->
                            <Border Grid.Row="3" Margin="10,10,10,0"
                        Background="{StaticResource PanelBgBrush}"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="10">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="▶  START COMPARISON"
                                Style="{StaticResource ConnectButton}"
                                Width="180" Height="36" FontSize="13" FontWeight="Bold"
                                Margin="0,0,10,0"
                                IsEnabled="{Binding OfflineCompare.IsNotComparing}"
                                Click="BtnStartCompare_Click"/>

                                    <Button Content="✕  CLEAR RESULTS"
                                Style="{StaticResource ProfessionalButton}"
                                Width="140" Height="36"
                                Click="BtnClearCompare_Click"/>
                                </StackPanel>
                            </Border>

                            <!-- ══════════════════════════════════════════════════════════════
     PROGRESS BAR
═══════════════════════════════════════════════════════════════ -->
                            <Border Grid.Row="4" Margin="10,10,10,0"
        Background="#FF0D1526"
        BorderBrush="{StaticResource AccentBrush}"
        BorderThickness="1" CornerRadius="4" Padding="12,8"
        Visibility="{Binding OfflineCompare.IsComparing, 
                     Converter={StaticResource BoolToVisConv}}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                       Text="{Binding OfflineCompare.ProgressText}"
                       FontSize="11" FontFamily="Consolas"
                       Foreground="{StaticResource TextBrush}"
                       VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="1"
                       FontSize="11" FontWeight="Bold"
                       FontFamily="Consolas"
                       Foreground="{StaticResource AccentBrush}">
                <Run Text="{Binding OfflineCompare.ProgressPercent, Mode=OneWay}"/>
                <Run Text="%"/>
                                        </TextBlock>
                                    </Grid>

                                    <ProgressBar Height="20"
                     Minimum="0" Maximum="100"
                     Value="{Binding OfflineCompare.ProgressPercent}"
                     Foreground="{StaticResource AccentBrush}"
                     Background="{StaticResource DarkBgBrush}"
                     BorderBrush="{StaticResource PanelBgBrush}"
                     BorderThickness="1"/>
                                </StackPanel>
                            </Border>
                            <!-- ══════════════════════════════════════════════════════════════
                     COMPARISON RESULTS (FIXED HEIGHT WITH SCROLLBAR)
                ═══════════════════════════════════════════════════════════════ -->
                            <Border Grid.Row="5" Margin="10,10,10,0"
                        Background="#FF080D18"
                        BorderBrush="{StaticResource PanelBgBrush}"
                        BorderThickness="2" CornerRadius="4">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                                    <TextBox Text="{Binding OfflineCompare.ComparisonResult, Mode=OneWay}"
                                 Background="Transparent"
                                 Foreground="{StaticResource GreenBrush}"
                                 FontFamily="Consolas"
                                 FontSize="10"
                                 BorderThickness="0"
                                 IsReadOnly="True"
                                 TextWrapping="NoWrap"
                                 AcceptsReturn="True"
                                 Padding="10"
                                 VerticalScrollBarVisibility="Disabled"
                                 HorizontalScrollBarVisibility="Disabled"/>
                                </ScrollViewer>
                            </Border>

                            <!-- ══════════════════════════════════════════════════════════════
                     STATUS BAR
                ═══════════════════════════════════════════════════════════════ -->
                            <Border Grid.Row="6" Margin="10,10,10,0"
                        Background="{StaticResource PanelBgBrush}"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Padding="12,7">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                   Text="STATUS: "
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource SubTextBrush}"
                                   VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1"
                                   Text="{Binding OfflineCompare.StatusMessage}"
                                   FontSize="10" FontFamily="Consolas"
                                   Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </TabItem>


            <!-- ═══════════════════════════════════════════════════════════
                 TAB 6: FRAME COUNTER DISPLAY
            ════════════════════════════════════════════════════════════ -->
            <TabItem Header="🔢 FRAME COUNTER" Style="{StaticResource DarkTabItem}">
                <Border Background="{StaticResource MidBgBrush}"
                        BorderBrush="{StaticResource PanelBgBrush}"
                        BorderThickness="1" CornerRadius="4" Margin="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Background="{StaticResource PanelBgBrush}"
                                CornerRadius="4,4,0,0" Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="VISUAL FRAME COUNTER DISPLAY" FontSize="14"
                                           FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="Large digital counter for frame monitoring"
                                           FontSize="11" Foreground="{StaticResource SubTextBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Counter display -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- PORT 1 counter -->
                            <Border Grid.Column="0" Background="#FF0D1526"
                                    BorderBrush="{StaticResource GreenBrush}"
                                    BorderThickness="2" CornerRadius="4"
                                    Margin="20">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="PORT 1" FontSize="16"
                                               FontWeight="Bold" Foreground="{StaticResource GreenBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,20"/>
                                    <TextBlock Text="{Binding Port1.TotalFrames}" FontSize="72"
                                               FontWeight="Bold" FontFamily="Consolas"
                                               Foreground="{StaticResource GreenBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="TOTAL FRAMES" FontSize="14"
                                               Foreground="{StaticResource SubTextBrush}"
                                               HorizontalAlignment="Center" Margin="0,10,0,0"/>

                                    <Separator Margin="40,20" Background="{StaticResource PanelBgBrush}"/>

                                    <Grid Margin="40,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="VALID" FontSize="11"
                                                       Foreground="{StaticResource SubTextBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Port1.ValidFrames}" FontSize="28"
                                                       FontWeight="Bold" FontFamily="Consolas"
                                                       Foreground="{StaticResource GreenBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="INVALID" FontSize="11"
                                                       Foreground="{StaticResource SubTextBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Port1.InvalidFrames}" FontSize="28"
                                                       FontWeight="Bold" FontFamily="Consolas"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- PORT 2 counter -->
                            <Border Grid.Column="2" Background="#FF0D1526"
                                    BorderBrush="{StaticResource YellowBrush}"
                                    BorderThickness="2" CornerRadius="4"
                                    Margin="20">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="PORT 2" FontSize="16"
                                               FontWeight="Bold" Foreground="{StaticResource YellowBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,20"/>
                                    <TextBlock Text="{Binding Port2.TotalFrames}" FontSize="72"
                                               FontWeight="Bold" FontFamily="Consolas"
                                               Foreground="{StaticResource YellowBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="TOTAL FRAMES" FontSize="14"
                                               Foreground="{StaticResource SubTextBrush}"
                                               HorizontalAlignment="Center" Margin="0,10,0,0"/>

                                    <Separator Margin="40,20" Background="{StaticResource PanelBgBrush}"/>

                                    <Grid Margin="40,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="VALID" FontSize="11"
                                                       Foreground="{StaticResource SubTextBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Port2.ValidFrames}" FontSize="28"
                                                       FontWeight="Bold" FontFamily="Consolas"
                                                       Foreground="{StaticResource GreenBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="INVALID" FontSize="11"
                                                       Foreground="{StaticResource SubTextBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Port2.InvalidFrames}" FontSize="28"
                                                       FontWeight="Bold" FontFamily="Consolas"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>

        </TabControl>

        <!-- ═══════════════════════════════════════════════════════════
             R4  STATUS BAR
        ════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4"
                Background="{StaticResource MidBgBrush}"
                BorderBrush="{StaticResource PanelBgBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding AppStatus}"
                           FontSize="10" FontFamily="Consolas"
                           Foreground="{StaticResource SubTextBrush}"
                           VerticalAlignment="Center"
                           Margin="10,0"
                           TextTrimming="CharacterEllipsis"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="10,0">
                    <TextBlock Text="Frame=26B  |  Extract[16-23]=8B  |  RS422@230400  |  "
                               FontSize="10"
                               Foreground="{StaticResource SubTextBrush}"/>
                    <TextBlock Text="ANVESHA TCRX V2.0"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>